# ── Build Artifacts ─────────────────────────────────────────────────
/target/
**/target/

# ── Rust ────────────────────────────────────────────────────────────
**/*.rs.bk

# ── IDE ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── macOS ───────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Node Logs (never commit operational logs) ────────────────────────
*.log
node_output*.log

# ── Bootnode / Validator Private Keys ───────────────────────────────
# These are libp2p network identity keys. Generate them per-server.
# See: ./target/release/tks-chain-node key generate-node-key
network/bootnode.key
network/bootnodes/*.key
*.nodekey
network/keystore/
keystore/

# ── Compiled Node Binaries ──────────────────────────────────────────
# Binary releases belong in GitHub Releases, not the repo.
# Use GitHub Actions (.github/workflows/release.yml) to publish.
releases/**/*-macos-arm64
releases/**/*-linux-x86_64
releases/**/*-linux-arm64
releases/**/*-windows-x86_64.exe
*.node-binary

# ── Test Artifacts ──────────────────────────────────────────────────
test_sig
/tmp/
calc-ecdsa/target/

# ── Secrets / Environment ────────────────────────────────────────────
.env
.env.*
secrets/
*.secret
*.pem
*.p12
